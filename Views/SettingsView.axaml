<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:TagForge.ViewModels"
             xmlns:ext="using:TagForge.Extensions"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:DataType="vm:SettingsViewModel"
             x:Class="TagForge.Views.SettingsView">
  
  <ScrollViewer Margin="30" HorizontalScrollBarVisibility="Disabled" ScrollViewer.BringIntoViewOnFocusChange="False">
      <StackPanel Spacing="30" Margin="0,0,20,0">
          
          <TextBlock Text="{ext:Localize Settings.Title}" FontSize="28" FontWeight="Bold"/>

          <!-- Language Selection -->
          <StackPanel Spacing="10">
               <TextBlock Text="{ext:Localize Settings.Language}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
               <Border Classes="card">
                   <StackPanel Spacing="10">
                       <TextBlock Text="{ext:Localize Settings.LanguageDescription}" Foreground="#CCC" FontSize="13"/>
                       <ComboBox ItemsSource="{Binding AvailableLanguages}" 
                                 SelectedItem="{Binding SelectedLanguage}"
                                 Width="200" HorizontalAlignment="Left"
                                 ToolTip.Tip="{x:Null}">
                           <ComboBox.ItemTemplate>
                               <DataTemplate>
                                   <TextBlock Text="{Binding NativeName}"/>
                               </DataTemplate>
                           </ComboBox.ItemTemplate>
                       </ComboBox>
                   </StackPanel>
               </Border>
          </StackPanel>



          <!-- Personas Management -->
          <StackPanel Spacing="10">
               <TextBlock Text="{ext:Localize Settings.Personas}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
               <Border Classes="card" Padding="0">
                   <Grid ColumnDefinitions="300, 1, *">
                       
                       <!-- Sidebar List -->
                       <Grid Grid.Column="0" RowDefinitions="*, Auto">
                           <ListBox ItemsSource="{Binding Personas}" SelectedItem="{Binding SelectedPersonaToEdit}" Height="300" Background="Transparent">
                               <ListBox.ItemTemplate>
                                   <DataTemplate>
                                       <TextBlock Text="{Binding Name}" Padding="5" TextWrapping="Wrap"/>
                                   </DataTemplate>
                               </ListBox.ItemTemplate>
                           </ListBox>
                           <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="5" Margin="10">
                               <Button Content="{ext:Localize Common.Add}" Command="{Binding AddPersonaCommand}" Classes="ghost"/>
                               <Button Content="{ext:Localize Common.Delete}" Command="{Binding DeletePersonaCommand}" Classes="ghost"/>
                           </StackPanel>
                       </Grid>
                       
                       <Rectangle Grid.Column="1" Fill="#333" Width="1"/>
                       
                       <!-- Edit Details -->
                       <Grid Grid.Column="2" Margin="20" RowDefinitions="Auto, Auto, *, Auto">
                           <TextBlock Text="{ext:Localize Settings.PersonaName}" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                           <TextBox Grid.Row="1" Text="{Binding SelectedPersonaToEdit.Name}" Margin="0,0,0,15" ToolTip.Tip="{x:Null}"
                                    IsEnabled="{Binding SelectedPersonaToEdit.IsNotReadOnly}"/>
                           
                           <TextBlock Grid.Row="2" Text="{ext:Localize Settings.SystemPrompt}" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                           <TextBox Grid.Row="2" Text="{Binding SelectedPersonaToEdit.SystemPrompt}" 
                                    AcceptsReturn="True" TextWrapping="Wrap" Height="150"
                                    VerticalAlignment="Top" Margin="0,20,0,0" ToolTip.Tip="{x:Null}"
                                    IsEnabled="{Binding SelectedPersonaToEdit.IsNotReadOnly}"/>

                           <Button Grid.Row="3" Content="{ext:Localize Common.SaveChanges}" Command="{Binding SavePersonasCommand}" 
                                   Classes="accent" HorizontalAlignment="Right" Margin="0,15,0,0"/>
                       </Grid>
                   </Grid>
               </Border>
          </StackPanel>

          <!-- Chat Rules Management -->
          <StackPanel Spacing="10">
               <TextBlock Text="{ext:Localize Settings.ChatRules}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
               <Border Classes="card" Padding="0">
                   <Grid ColumnDefinitions="300, 1, *">
                       
                       <!-- Sidebar List -->
                       <Grid Grid.Column="0" RowDefinitions="*, Auto">
                           <ListBox ItemsSource="{Binding ChatRules}" SelectedItem="{Binding SelectedChatRuleToEdit}" Height="300" Background="Transparent">
                               <ListBox.ItemTemplate>
                                   <DataTemplate>
                                       <TextBlock Text="{Binding Name}" Padding="5" TextWrapping="Wrap"/>
                                   </DataTemplate>
                               </ListBox.ItemTemplate>
                           </ListBox>
                           <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="5" Margin="10">
                               <Button Content="{ext:Localize Common.Add}" Command="{Binding AddChatRuleCommand}" Classes="ghost"/>
                               <Button Content="{ext:Localize Common.Delete}" Command="{Binding DeleteChatRuleCommand}" Classes="ghost"/>
                           </StackPanel>
                       </Grid>
                       
                       <Rectangle Grid.Column="1" Fill="#333" Width="1"/>
                       
                       <!-- Edit Details -->
                       <Grid Grid.Column="2" Margin="20" RowDefinitions="Auto, Auto, *, Auto">
                           <TextBlock Text="{ext:Localize Settings.ChatRuleName}" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                           <TextBox Grid.Row="1" Text="{Binding SelectedChatRuleToEdit.Name}" Margin="0,0,0,15" ToolTip.Tip="{x:Null}"
                                    IsEnabled="{Binding SelectedChatRuleToEdit.IsNotReadOnly}"/>
                           
                           <TextBlock Grid.Row="2" Text="{ext:Localize Settings.ChatRuleInstruction}" Foreground="#888" FontSize="12" Margin="0,0,0,5"/>
                           <TextBox Grid.Row="2" Text="{Binding SelectedChatRuleToEdit.Instruction}" 
                                    AcceptsReturn="True" TextWrapping="Wrap" Height="150"
                                    VerticalAlignment="Top" Margin="0,20,0,0" ToolTip.Tip="{x:Null}"
                                    IsEnabled="{Binding SelectedChatRuleToEdit.IsNotReadOnly}"/>
 
                           <Button Grid.Row="3" Content="{ext:Localize Common.SaveChanges}" Command="{Binding SaveChatRulesCommand}" 
                                   Classes="accent" HorizontalAlignment="Right" Margin="0,15,0,0"/>
                       </Grid>
                   </Grid>
               </Border>
          </StackPanel>
 
          <!-- Extra Maintenance -->
          <StackPanel Spacing="10">
               <TextBlock Text="{ext:Localize Settings.Extra}" FontSize="18" FontWeight="SemiBold" Foreground="#FF5555"/>
               <Border Classes="card" BorderBrush="#442222" BorderThickness="1" Padding="20">
                    <WrapPanel Orientation="Horizontal">
                        <Button Command="{Binding ExportHistoryCommand}" Classes="accent" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M2,12H4V17H20V12H22V17A2,2 0 0,1 20,19H4A2,2 0 0,1 2,17V12M12,15L17,10H14V3H10V10H7L12,15Z" Width="14" Height="14"/>
                                <TextBlock Text="{ext:Localize Settings.ExportHistory}"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ImportHistoryCommand}" Classes="accent" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M2,12H4V17H20V12H22V17A2,2 0 0,1 20,19H4A2,2 0 0,1 2,17V12M12,2L7,7H10V14H14V7H17L12,2Z" Width="14" Height="14"/>
                                <TextBlock Text="{ext:Localize Settings.ImportHistory}"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ResetSettingsCommand}" Classes="ghost" Margin="0" Foreground="#FF5555">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <PathIcon Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" Width="14" Height="14"/>
                                <TextBlock Text="{ext:Localize Settings.Reset}"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
               </Border>
          </StackPanel>

          <!-- About Section -->
          <StackPanel Spacing="10">
               <TextBlock Text="{ext:Localize Settings.About}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
               <Border Classes="card">
                   <StackPanel Spacing="15">
                       <StackPanel Orientation="Horizontal" Spacing="15">
                           <Image Width="64" Height="64" Source="/Assets/Logo.ico"/>
                           <StackPanel VerticalAlignment="Center">
                               <TextBlock Text="TagForge" FontSize="20" FontWeight="Bold"/>
                               <TextBlock Text="{Binding AppVersion}" Foreground="#AAA"/>
                           </StackPanel>
                       </StackPanel>
                       <TextBlock Text="{ext:Localize Settings.Description}" Foreground="#CCC"/>
                       
                       <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">

                           <Button Command="{Binding OpenUrlCommand}" CommandParameter="https://github.com/SiliconeShojo/TagForge" Classes="ghost">
                               <StackPanel Orientation="Horizontal" Spacing="8">
                                   <PathIcon Data="M12,2A10,10 0 0,0 2,12C2,16.42 4.87,20.17 8.84,21.5C9.34,21.58 9.5,21.27 9.5,21C9.5,20.77 9.5,20.14 9.5,19.31C6.73,19.91 6.14,17.97 6.14,17.97C5.68,16.81 5.03,16.5 5.03,16.5C4.12,15.88 5.1,15.9 5.1,15.9C6.1,15.97 6.63,16.93 6.63,16.93C7.5,18.45 8.97,18 9.54,17.76C9.63,17.11 9.89,16.67 10.17,16.42C7.95,16.17 5.62,15.31 5.62,11.5C5.62,10.39 6,9.5 6.65,8.79C6.55,8.54 6.2,7.5 6.75,6.15C6.75,6.15 7.59,5.88 9.5,7.17C10.29,6.95 11.15,6.84 12,6.84C12.85,6.84 13.71,6.95 14.5,7.17C16.41,5.88 17.25,6.15 17.25,6.15C17.8,7.5 17.45,8.54 17.35,8.79C18,9.5 18.38,10.39 18.38,11.5C18.38,15.32 16.04,16.16 13.81,16.41C14.17,16.72 14.5,17.33 14.5,18.26C14.5,19.6 14.5,20.68 14.5,21C14.5,21.27 14.66,21.59 15.17,21.5C19.14,20.16 22,16.42 22,12A10,10 0 0,0 12,2Z" Width="16" Height="16"/>
                                   <TextBlock Text="GitHub" VerticalAlignment="Center"/>
                               </StackPanel>
                           </Button>

                           <Button Command="{Binding OpenUrlCommand}" CommandParameter="https://github.com/SiliconeShojo/TagForge/wiki" Classes="ghost">
                               <StackPanel Orientation="Horizontal" Spacing="8">
                                   <PathIcon Data="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 4h5v8l-2.5-1.5L6 12V4z" Width="16" Height="16"/>
                                   <TextBlock Text="{ext:Localize Settings.Wiki}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding OpenUrlCommand}" CommandParameter="https://ko-fi.com/siliconeshojo" Classes="ghost">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Image Source="/Assets/Icons/KoFi.png" Width="16" Height="16"/>
                                    <TextBlock Text="Ko-fi" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                   </StackPanel>
               </Border>
          </StackPanel>

      </StackPanel>
  </ScrollViewer>
</UserControl>
